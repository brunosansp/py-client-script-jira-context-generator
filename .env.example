# Configurações do Jira para o Context Generator
# Copie este arquivo para .env e preencha com suas credenciais

# URL da sua instância do Jira (incluindo https://)
JIRA_URL=https://sua-empresa.atlassian.net

# Seu email cadastrado no Jira
JIRA_EMAIL=seu-email@empresa.com

# Token de API do Jira
# Para gerar: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=seu-token-aqui
